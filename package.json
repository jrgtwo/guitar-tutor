{
  "name": "fretwork-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "lib",
    "example",
    "metronome",
    "adkit"
  ],
  "scripts": {
    "dev": "pnpm --filter example dev",
    "build": "pnpm --filter example build",
    "preview": "pnpm --filter example preview",
    "dev:metronome": "pnpm --filter @fretwork/metronome dev",
    "build:metronome": "pnpm --filter @fretwork/metronome build",
    "test": "pnpm --filter lib test && pnpm --filter example test",
    "test:lib": "pnpm --filter lib test",
    "test:example": "pnpm --filter example test",
    "test:adkit": "pnpm --filter adkit test"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["ffmpeg-static"]
  }
}
