{
  "name": "fretwork-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "lib",
    "example"
  ],
  "scripts": {
    "dev": "npm run dev -w example",
    "build": "npm run build -w example",
    "preview": "npm run preview -w example",
    "test": "npm run test -w lib && npm run test -w example",
    "test:lib": "npm run test -w lib",
    "test:example": "npm run test -w example"
  }
}
