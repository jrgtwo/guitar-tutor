# Supabase configuration.
#
# 1. Copy this file to `.env.local` (which is gitignored).
# 2. Fill in the real values from your Supabase project dashboard:
#      Project Settings → API
#         - URL              → VITE_SUPABASE_URL
#         - anon / public key → VITE_SUPABASE_ANON_KEY
#
# The anon key is a publishable client key, designed to be exposed in browser
# bundles. RLS policies on the database are what actually protect user data.
# DO NOT put the service_role key here — that's a server-only secret.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
